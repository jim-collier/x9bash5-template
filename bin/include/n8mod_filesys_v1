## Functions

fDoesPathExist(){
	##	Purpose: Basically the same as `[[ -e "${fsPath}" ]]`.
	##	  No big benefit over that except this errors on empty.
	[[ -n "${1:-}" ]] || fThrowError "No path specified."
	[[ -e "${1:-}" ]] || return 1
	return 0
}

fPathMustExist(){
	## Purpose: Like fDoesPathExist(), except errors if path not exist.
	[[ -n "${1:-}" ]] || fThrowError "No path specified."
	[[ -e "${1:-}" ]] || fThrowError "Specified path not found: '${1:-}'."
}

fDoesDirExistWithContents(){
	##	Purpose: Success (0) if dir exists and has contents. Otherwise failure (>0). Only errors if nothing specified.
	local checkPath="${1:-}"
	[[ -n "${checkPath}" ]] || fThrowError "No folder path specified."
	checkPath="${checkPath%%/}" ; { [[ -z "${checkPath}" ]] && checkPath='/'; } || checkPath="${checkPath}/"; readonly checkPath
	[[ -d "${checkPath}" ]]                                  ||  return 1
	[[ -n "$(ls -1A "${checkPath}" 2>/dev/null || true)" ]]  ||  return 1
	return 0
}

fIsInPath(){
	## Purpose: Success (0) if executable is found in $PATH. Otherwise failure (>0). Only errors if nothing specified.
	[[ -n "${1:-}" ]]           ||  { fThrowError 'No executable specified to check for in $PATH.'  ; return 1; }
	which "${1:-}" 2>/dev/null  ||  return 1
	return 0
}

fMustBeInPath(){
	## Purpose: Like fIsInPath, except errors if not.
	[[ -n "${1:-}" ]]           ||  { fThrowError 'No executable specified to check for in $PATH.'  ; return 1; }
	which "${1:-}" 2>/dev/null  ||  { fThrowError "Executable not found in \$PATH: ${1:-}"          ; return 1; }
}

fSafer_rm(){
	local -r  rmDir="${1:-}"       ; shift || :  ## Arg <REQUIRED>: Dir to delete.
	local -ri ignoreError=${1:-0}  ; shift || :  ## Arg [optional]: Ignore error on rm. [Default 0]
	local -ri mustBeEmpty=${1:-1}  ; shift || :  ## Arg [optional]: Dir must be empty, or error. [Default 1]
	[[ -n "${rmDir}"                  ]] || fThrowError  "No folder to delete specified."
	[[ -d "${rmDir}"                  ]] || fThrowError  "Folder to delete doesn't seem to exist: '${rmDir}'."
	[[    "${rmDir}"    == "/"        ]] && fThrowError  "I refuse to try to delete '/'!."
	[[    "${rmDir%%/}" == "${HOME}"  ]] && fThrowError  "I refuse to try to delete '${HOME}'!."
	{ ((mustBeEmpty)) && fDoesDirExistWithContents "${rmDir}"; }  &&  fThrowError  "Can't delete non-empty folder '${rmDir}/'."
	fEcho "Removing folder '${rmDir}' ..."
	if ((ignoreError)); then  rm -rf "${rmDir}" 2>/dev/null || true
	else                      rm -rf "${rmDir}"
	fi
:;}



