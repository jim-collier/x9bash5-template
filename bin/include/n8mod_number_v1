## Functions

fIsBool(){
	##	Purpose: Function return val of 0 [success] if input is boolean, >0 [failure] if not.
	local -r inputVal="${1:-}"  # ; shift || :  ##
	case "${inputVal,,}" in
		"1"|"true"|"yes"|"y"|"t")                        return 0  ;;  ## 0 for function return means "success", it is boolean.
		"0"|"false"|"no"|"n"|"f")                        return 0  ;;  ## 0 for function return means "success", it is boolean.
		*) [[ "${inputVal}" =~ $BREGEX_IS_PURE_INT ]] && return 0  ;;  ## 0 for function return means "success", it is boolean.
	esac
	return 1  ## 1 for function return means "failure", it is not boolean.
}

fIsBoolTrue(){
	##	Purpose: Function return val of 0 [success] for boolean input that is "true", >0 [failure] if "false".
	##           The function return code, and traditional boolean integer values, are reversed in this case.
	##	         Errors on non-boolean input.
	local -r inputVal=$1  # ; shift || :  ##
	case "${inputVal,,}" in
		"1"|"true"|"yes"|"y"|"t")  return 0  ;;  ## 0 means function "success", or boolean true.
		"0"|"false"|"no"|"n"|"f")  return 1  ;;  ## >0 means "failure", or boolean false.
		*)
			if [[ "${inputVal}" =~ $BREGEX_IS_PURE_INT ]]; then
				((inputVal == 0)) && return 1  ## 1 for function return means "failure", or boolean false.
				return 0  ## 0 means function "success", or boolean true.
			fi
		;;
	esac
	fThrowError "Input value is not boolean: '${inputVal}'."
}

fGetRandomInt(){
	##	Purpose: Return a cryptographically valid integer between low and high ints, inclusive.
	##	WARNING: Bash >= 5.1 only.
	##	This is ~40x faster than using subshells e.g. for `shuf`, and ~4x faster than fGetRandomInt_SlowerBetter().
	## Validate nameref args:
	[[ -v 1 ]] || fThrowError "Calling function must pass a nameref to receive this function's integer output, as arg1."
	## Gather args
	local -n  ptr_Output_s8hk7=$1  ; shift || :  ## <REQUIRED>: Caller nameref for return int.
	local -ri intLow=${1:-0}       ; shift || :  ## <REQUIRED>: Lowest int, inclusive. Can be negative.
	local -ri intHigh=${1:-1}      ; shift || :  ## <REQUIRED>: Highest int, inclusive. Upper limit: (intHigh - intLow + 1) ≤ 4,294,967,295.
	## Init
	ptr_Output_s8hk7=0
	## Logic
	local -i range=$(( intHigh - intLow + 1 ))
	local -i max_unbiased=$(( (2**32 / range) * range - 1 ))  ## Largest multiple of range that fits in 32 bits. Values above this would bias lower buckets if included.
	local -i val
	while true; do
		val=$SRANDOM
		(( val <= max_unbiased )) && break
	done
	ptr_Output_s8hk7=$(( intLow + (val % range) ))
:;}


fGetRandomInt_SlowerBetter(){
	##	Purpose: Return a cryptographically valid integer between low and high ints, inclusive.
	##	Note: $RANDOM can do similar, but is not uniformly random, or crypto-secure.
	##	This is 10x faster than using subshells e.g. for `shuf`.
	## Validate nameref args:
	[[ -v 1 ]] || fThrowError "Calling function must pass a nameref to receive this function's integer output, as arg1."
	## Gather args
	local -n  ptr_Output_s8hk7=$1  ; shift || :  ## <REQUIRED>: Caller nameref for return int.
	local -ri intLow=${1:-0}       ; shift || :  ## <REQUIRED>: Lowest int, inclusive. Can be negative.
	local -ri intHigh=${1:-1}      ; shift || :  ## <REQUIRED>: Highest int, inclusive. Upper limit: (intHigh - intLow + 1) ≤ 4,294,967,295.
	## Init
	ptr_Output_s8hk7=0
	## Logic
	local -i range=$(( intHigh - intLow + 1 ))
	local -i bytes_needed=$(( (range < 256) ? 1 : (range < 65536) ? 2 : 4 ))
	local -i max_unbiased=$(( (256**bytes_needed / range) * range - 1 ))
	local -i val
	local raw
	while true; do
		IFS= read -r -d '' -n "$bytes_needed" raw < /dev/urandom
		val=0
		local -i i
		for (( i=0; i<bytes_needed; i++ )); do
			printf -v byte '%d' "'${raw:$i:1}"
			val=$(( (val * 256) + byte ))
		done
		(( val <= max_unbiased )) && break
	done
	ptr_Output_s8hk7=$(( intLow + (val % range) ))
:;}



