## String functions
[[ ! -v BUILD_QUOTED_PARAMS_CHECK_PATTERN ]] && declare -gr BUILD_QUOTED_PARAMS_CHECK_PATTERN=$'[][[:space:]|&;()<>`*?$!~{}\'\"#=,%@\\]'  ## If an arg has any of these in it, it needs quoting.
fBuildQuotedParams(){
	## Given up to 99 arguments following the parent variable to populate, populates that variable with a string, with the original arguments either as-is, or in quotes if they need it.
	local -n varName_1mtkp9p=$1 ; shift || true  ## First argument is caller's variable to put results in. Remainging <= 99 variables are to put in quoted string.
	## Build arg string out of remaining args. Note: ${!i}" refers to function arguments.
	local -i maxIdx=0
	for i in {1..99}; do [[ -n "${!i}" ]] && maxIdx=$i; done
	for i in $(seq 1 $maxIdx); do
		((i > 1)) && varName_1mtkp9p="${varName_1mtkp9p} "
		if [[ "${!i}" =~ ${BUILD_QUOTED_PARAMS_CHECK_PATTERN} ]]; then  varName_1mtkp9p="${varName_1mtkp9p}\"${!i}\""  ## Needs quoting
		else                                                            varName_1mtkp9p="${varName_1mtkp9p}${!i}"      ## Doesn't need quoting
		fi
	done
}


