if [[ -z "${THIS_LIB_FILE_PATH_t5j9j+x}" ]]; then
	## Constants
	declare -r  THIS_LIB_FILE_PATH_t5j9j="$(realpath -e "${BASH_SOURCE[0]}")"
	declare -r  THIS_LIB_FILE_NAME_t5j9j="$(basename "${THIS_LIB_FILE_PATH_t5j9j}")" #...: Replace with native bash function when ready.
	declare -r  THIS_LIB_DIR_PATH_t5j9j="$(dirname "${THIS_LIB_FILE_PATH_t5j9j}")" #.....: Replace with native bash function when ready.
	## Variables
	declare  -i wasShown_Version=0
	declare  -i wasShown_Copyright=0
	declare  -i wasShown_About
	declare  -i wasShown_Syntax
fi


##•••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••
## Show version, copyright, about, syntax
fShowVersion(){
	((doQuietly || wasShown_Version)) && return 0
	fEcho_Clean "${THIS_FILENAME} v${THIS_VERSION} build ${THIS_BUILD}"
	wasShown_Version=1
}
fShowCopyright(){
	((doQuietly || wasShown_Copyright)) && return 0
	local copyrightStr=""
	wasShown_Version=0
	copyrightStr+="$(fVersion)\n"
	copyrightStr+="Copyright © ${THIS_COPYRIGHT_YEARS} ${THIS_AUTHOR}.\n"
	case "${LICENSE_SPDX,,}" in
		"GPL-2.0-or-later")
			copyrightStr+="Licensed under the GNU General Public License v2.0 or later. Full text at:\n"
			copyrightStr+="  https://spdx.org/licenses/GPL-2.0-or-later.html\n"
		;;
		*) fThrowError "Sorry, I haven't been programmed yet to display license '${LICENSE_SPDX}'." ;;
	esac
	copyrightStr+="No warranty."
	fEcho_Clean; fEcho_Clean "${copyrightStr}"; fEcho_Clean
	wasShown_Copyright=1
}
fShowAbout(){
	((doQuietly || wasShown_About)) && return 0
	## Arg
	local -n varName_AboutText_t5j9j=$1
	[[ -v varName_AboutText_t5j9j && -n "${varName_AboutText_t5j9j:-}" ]] || fThrowError "The one argument to this function must be a variable containing 'about' text."
	fEcho_Clean; fEcho_Clean "${varName_AboutText_t5j9j}"; fEcho_Clean
	wasShown_About=1
}
fShowSyntax(){
	((doQuietly || wasShown_Syntax)) && return 0
	## Arg
	local -n varName_SyntaxText_t5j9j=$1
	[[ -v varName_SyntaxText_t5j9j && -n "${varName_SyntaxText_t5j9j:-}" ]] || fThrowError "The one argument to this function must be a variable containing 'syntax' text."
	fEcho_Clean; fEcho_Clean "${varName_SyntaxText_t5j9j}"; fEcho_Clean
	wasShown_Syntax=1
}


