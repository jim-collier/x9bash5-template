if [[ -z "${doQuietly+x}" ]]; then
	declare -i doQuietly
	declare -i doPromptToContinue
	declare -i ARGS_AT_LEAST_ONE_IS_REQUIRED  || :
	declare    THIS_VERSION                   || :
	declare    THIS_BUILD                     || :
	declare    THIS_COPYRIGHT_YEARS           || :
	declare    THIS_AUTHOR                    || :
	declare    LICENSE_SPDX                   || :
	declare    THIS_FILEPATH                  || :
	declare    THIS_FILENAME                  || :
	declare    THIS_DIRPATH                   || :
fi

